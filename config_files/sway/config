bindsym Control+Shift+Mod1+d exec ~/.config/sway/open_website_in_firefox.sh https://www.deepl.com
bindsym Control+Shift+Mod1+k exec ~/.config/sway/open_website_in_firefox.sh https://keep.google.com
bindsym Control+Shift+Mod1+s exec ~/.config/sway/open_website_in_firefox.sh https://scholar.google.com
bindsym Control+Shift+Mod1+t exec ~/.config/sway/open_website_in_firefox.sh https://translate.google.com
bindsym Control+Shift+Mod1+g exec ~/.config/sway/open_website_in_firefox.sh https://github.com/

# Open VS Code Notes
bindsym Control+Shift+Mod1+n workspace number $ws10; exec code "$HOME/Nextcloud/TODO_Lists_VSCode"

# Move whole workspace to different outputs (monitors)
bindsym $mod+Mod1+Right move workspace to output right
bindsym $mod+Mod1+Left move workspace to output left 
# Lock screen
# bindsym $mod+l exec swaylock -f
# bindsym $mod+l exec --no-startup-id gdmflexiserver
bindsym $mod+l exec gtklock -d



