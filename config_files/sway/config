################################################################################
###  Mouse Commands
################################################################################
# The middle button over a titlebar kills the window
bindsym --release button2 kill

# The middle button and a modifier over any part of the window kills the window
bindsym --whole-window $mod+button2 kill

# The right button over a titlebar toggles floating
bindsym button3 floating toggle

# The right button and modifier over any part of a the window toggles floating
bindsym --whole-window $mod+button3 floating toggle

# Rearrange the windows in the current workspace to grid layout (prioritizes more columns for wide screens)
bindsym $mod+Shift+g exec ~/.config/sway/sway_grid.sh



