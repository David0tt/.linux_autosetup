        position top
        status_command i3status --config ~/.config/sway/i3status.conf
        # tray_output none # Do not show tray output
        tray_output DP-1 # show tray on DP-1 (sway has no X11 "primary" concept; specify output directly)
        # tray_output HDMI-1 # sometimes a specific display has to be named
        font pango:monospace 18  # update if using a Wayland workspace icon daemon
        # font pango:i3WorkspaceDeamonIconFont 20
        height 33
        # font pango:monospace 18
}

