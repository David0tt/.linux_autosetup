smart_borders on

################################################################################
###  Default Workspaces
################################################################################

# I use the convention: 
# $ws9: use this for firefox with all kinds of websites accessed by shortcuts (ctrl+shift+c/k/s/d/t/g)
# $ws10: use this for VSCode TODO_Lists_VSCode (acessed via ctrl+shift+alt+n)
# All other workspaces have no specific purpose

# Keep the Notes VS Code window on WS 9
assign [class="Code" title=".*TODO_Lists_VSCode.*"] $ws10
# assign [app_id="code"] $ws10  # use app_id if VS Code runs as native Wayland (--ozone-platform=wayland)
# assign [class="Code"] $ws10

# Custom Float rules
for_window [title="fzf_launcher"] floating enable, resize set 800 600, move position center

# TODO: in the future, it would be nice to spawn the selection window so its left border is aligned with the cursor
for_window [title="cliphist_fzf"] floating enable, resize set 800 600, move position cursor
for_window [title="cliphist_delete"] floating enable, resize set 800 600, move position cursor

# Waybar apps with quicklaunch icons
for_window [app_id="^nextcloud$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [class="^Nextcloud$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [title="^Nextcloud.*$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [app_id="^nm-connection-editor$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [class="^Nm-connection-editor$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [title="^Network Connections$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [app_id="^blueman-manager$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [class="^Blueman-manager$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [title="^Bluetooth.*$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [app_id="^org\.pulseaudio\.pavucontrol$|^pavucontrol$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [class="^Pavucontrol$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt
for_window [title="^Volume Control$"] floating enable, resize set 45 ppt 70 ppt, move position 55 ppt 0 ppt

################################################################################
###  Mouse Commands
################################################################################
# The middle button over a titlebar kills the window
bindsym --release button2 kill

# The middle button and a modifier over any part of the window kills the window
bindsym --whole-window $mod+button2 kill

# The right button over a titlebar toggles floating
bindsym button3 floating toggle

# The right button and modifier over any part of a the window toggles floating
bindsym --whole-window $mod+Mod1+button3 floating toggle

################################################################################
###  Custom Keybindings
################################################################################

# Rearrange windows to grid
bindsym $mod+Shift+g exec ~/.config/sway/sway_grid.sh


# Clipboard manager
# Clipboard history picker in st + fzf.
bindsym $mod+v exec st -t cliphist_fzf -e sh -c 'cliphist list | fzf --layout=reverse | cliphist decode | wl-copy && swaymsg exec "wtype -s 150 -M ctrl -k v -m ctrl"'

# Delete from history
bindsym $mod+Shift+v exec st -t cliphist_delete -e sh -c 'cliphist list | fzf --layout=reverse --prompt=\"Delete From Clipboard: \" | cliphist delete'

# Other considerations
# Sadly diodon does not work on wayland
